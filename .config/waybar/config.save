{

    "layer": "top", // Waybar at top layer

    // "position": "bottom", // Waybar position (top|bottom|left|right)

    "height": 30, // Waybar height (to be removed for auto height)

    // "width": 1280, // Waybar width

    // Choose the order of the modules

    "modules-center": ["sway/window"],

    "modules-left": ["sway/workspaces", "sway/mode"],

    "modules-right": ["pulseaudio", "network", "cpu", "memory", "temperature", "battery", "clock", "tray"],

    // Modules configuration

     "sway/workspaces": {

         "disable-scroll": true,

         "all-outputs": false,

         "format": "{icon}",

         "format-icons": {

             "urgent": "пЃЄ"
         }

     },

    "sway/mode": {

        "format": "<span style=\"italic\">{}</span>"

    },

    "tray": {

        // "icon-size": 21,

        "spacing": 10

    },

    "clock": {

        "tooltip-format": "{:%Y-%m-%d | %H:%M}",

        "format-alt": "{:%Y-%m-%d}"

    },

    "cpu": {

        "format": "{usage}% п‹›",

        "tooltip": false
    },

    "memory": {

        "format": "{}% пѓ‰"

    },

    "temperature": {

        // "thermal-zone": 2,

        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",

        "critical-threshold": 80,

        // "format-critical": "{temperatureC}В°C {icon}",

        "format": "{temperatureC}В°C {icon}",

        "format-icons": ["пќ«", "п‹‰", "пЃ±"]

    },


    "battery": {

        "states": {

            // "good": 95,

            "warning": 30,

            "critical": 15

        },

        "format": "{capacity}% {icon}",

        "format-charging": "{capacity}% пѓ§",

        "format-plugged": "{capacity}% п‡¦",

        "format-alt": "{time} {icon}",

        // "format-good": "", // An empty format will hide the module

        // "format-full": "",

        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],

	"bat": "BAT0"

    },

    "battery#bat1": {

        "bat": "BAT0",

	"states": {

            // "good": 95,

            "warning": 30,

            "critical": 15

        },

        "format": "{capacity}% {icon}",

        "format-charging": "{capacity}% пѓ§",

        "format-plugged": "{capacity}% п‡¦",

        "format-alt": "{time} {icon}",

        // "format-good": "", // An empty format will hide the module

        // "format-full": "",

        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],

    	"bat": "BAT0"

    },

    "network": {

        "format-wifi": "{signalStrength}% п‡«",

        "format-ethernet": "{ifname}: {ipaddr}/{cidr} оѕҐ",

        "format-linked": "{ifname} (No IP) оѕҐ",

        "format-disconnected": "пЃЄ  п‡«",

    },

    "pulseaudio": {

        // "scroll-step": 1, // %, can be a float

        "format": "{volume}% {icon}",

        "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",

        "format-muted": "<span font=\"IcoFont\">о±¬</span>   {format_source}",

        "format-source": "{volume}% п„°",

        "format-source-muted": "п„±",

        "format-icons": {

            "headphones": "пЂҐ",

            "handsfree": "п–ђ",

            "headset": "п–ђ",

            "phone": "п‚•",

            "portable": "п‚•",

            "car": "п†№",

            "default": ["пЂ¦", "пЂ§", "пЂЁ"]

        },

        "on-click": "pavucontrol"
    }
}
